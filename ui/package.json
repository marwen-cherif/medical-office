{
  "name": "cabinet-crm-ui",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Frontend React (Vite + Tailwind v4 + shadcn) du Cabinet CRM — adossé au sidecar FastAPI.",
  "scripts": {
    "dev": "vite",
    "server": "python ../crm_server.py --port 8765 --token devtoken --reload",
    "dev:all": "concurrently -n api,web -c blue,green -k \"npm:server\" \"npm:dev\"",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "gen:api": "openapi-typescript ./openapi.json -o ./src/api/schema.d.ts",
    "dev:tauri": "tauri dev",
    "build:tauri": "tauri build",
    "tauri": "tauri"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.1",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.18",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-popover": "^1.1.17",
    "@radix-ui/react-select": "^2.1.4",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-tabs": "^1.1.2",
    "@tanstack/react-query": "^5.62.7",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "lucide-react": "^0.469.0",
    "openapi-fetch": "^0.13.4",
    "react": "^19.0.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.2",
    "react-odontogram": "0.5.6",
    "react-router-dom": "^7.1.1",
    "sonner": "^1.7.2",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@tauri-apps/cli": "^2.1.0",
    "@types/node": "^22.20.0",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^9.1.0",
    "openapi-typescript": "^7.5.0",
    "playwright-core": "^1.61.1",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.7.2",
    "vite": "^8.1.0"
  }
}
