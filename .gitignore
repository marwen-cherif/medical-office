__pycache__/
*.pyc
*.spec
# ...sauf les specs de build du CRM (necessaires a build-crm.bat)
!crm-desktop.spec
!crm-web.spec
!crm-server.spec
build/
dist/
.venv/
venv/

# Sortie et fichiers utilisateur (garder le dossier via .gitkeep)
output/*

# Exports generes (referentiel d'actes en .xlsx, etc. - ne pas versionner)
exports/

# Sauvegardes de la base (donnees patients - ne pas versionner)
backups/

# Base de donnees locale du CRM (donnees patients - ne pas versionner)
data/
crm/__pycache__/

# Journaux runtime (mailjet.log, ai.log) : peuvent contenir emails / reponses IA
logs/

# Numero de build genere a chaque build (build-crm.bat) - ne pas versionner
crm/_build_info.py

# Secrets Mailjet (cles API) - ne pas versionner
config.ini

# Reglages locaux Claude Code (specifiques a la machine)
.claude/settings.local.json

# Worktrees internes de Claude Code (repertoire de travail, ne pas versionner)
.claude/worktrees/

# Modeles utilisateur (garder le dossier, pas les .docx perso)
templates/*.docx

# Garder les dossiers
!output/.gitkeep
